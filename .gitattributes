# Keep line endings deterministic. Shell scripts and code MUST be LF or they
# break on the Linux servers this panel runs on (a CRLF shebang fails to exec).
* text=auto eol=lf

*.sh    text eol=lf
*.bash  text eol=lf
*.go    text eol=lf
*.html  text eol=lf
*.toml  text eol=lf
*.service text eol=lf
*.socket  text eol=lf
*.timer   text eol=lf
tunnel/tunnelctl text eol=lf

# Known binaries (never touch EOL / never diff as text)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.dat binary
*.db binary
*.gz binary
*.zip binary
